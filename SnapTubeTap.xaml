<UserControl x:Class="KSO.SnapTubeTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lang="clr-namespace:KSO.Helpers"
             Background="#1E1E1E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. شريط البحث -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="{x:Static lang:Lang.SnapTubeTab}" FontSize="18" FontWeight="Bold" Foreground="#FF0000" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="txtCourseSearch" Width="350" Height="35" FontSize="14"
                     Background="#2D2D2D" Foreground="White" BorderBrush="#FF0000"
                     VerticalContentAlignment="Center" Padding="10" 
                     ToolTip="{x:Static lang:Lang.SnapTubeSearch}"/>
            <Button x:Name="btnSearchCourse" Content="بحث" Width="100" Height="35" Margin="10,0,0,0"
                    Background="#FF0000" Foreground="White" FontWeight="Bold"
                    Click="BtnSearchCourse_Click"/>
            <Button x:Name="btnCreateFolder" Content="{x:Static lang:Lang.SnapTubeCreateFolder}" Width="120" Height="35" Margin="10,0,0,0"
                    Background="#2D2D2D" Foreground="White"
                    Click="BtnCreateFolder_Click"/>
        </StackPanel>

        <!-- 2. تبويبات SnapTube -->
        <TabControl x:Name="TabSnap" Grid.Row="1" Background="#2D2D2D" Foreground="White"
                    SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="{x:Static lang:Lang.SnapTubeVideos}" Tag="videos"/>
            <TabItem Header="{x:Static lang:Lang.SnapTubePlaylists}" Tag="playlists"/>
            <TabItem Header="{x:Static lang:Lang.SnapTubeChannels}" Tag="channels"/>
            <TabItem Header="{x:Static lang:Lang.SnapTubeAll}" Tag="all"/>
        </TabControl>

        <!-- 3. النتائج + دبل كليك للتشغيل -->
        <ListView x:Name="lvSnapResults" Grid.Row="2" Background="#2D2D2D" Foreground="White"
                  BorderBrush="#FF0000" ScrollViewer.ScrollChanged="ScrollViewer_ScrollChanged"
                  MouseDoubleClick="LvSnapResults_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Image Source="{Binding Thumbnail}" Width="120" Height="68" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Width="400"/>
                            <TextBlock Text="{Binding Duration}" Foreground="#AAAAAA" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 4. زر التحميل -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="{x:Static lang:Lang.SnapTubeSelected}" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock x:Name="txtSelectedCount" Text="0" Foreground="#FF0000" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button x:Name="BtnDownloadSelected" Content="{x:Static lang:Lang.SnapTubeDownload}" Width="150" Height="40"
                    Background="LimeGreen" Foreground="Black" FontWeight="Bold" FontSize="14"
                    Click="BtnDownloadSelected_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
